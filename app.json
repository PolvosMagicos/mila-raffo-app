{
  "expo": {
    "name": "mila-raffo-app",
    "slug": "mila-raffo-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-mila.png",
    "scheme": "milaraffoapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EC7C43",
        "foregroundImage": "./assets/images/logo-mila.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo-mila.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#EC7C43",
          "image": "./assets/images/logo-mila.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "android": {
            "image": "./assets/images/logo-mila.png",
            "imageWidth": 240,
            "backgroundColor": "#EC7C43"
          },
          "ios": {
            "backgroundColor": "#EC7C43"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
